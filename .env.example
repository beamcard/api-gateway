# api-gateway — prod env. Set in the platform dashboard.
SPRING_PROFILES_ACTIVE=prod

USER_SERVICE_URL=https://<user-service-url>
PROFILE_SERVICE_URL=https://<profile-service-url>

JWKS_URI=https://<user-service-url>/.well-known/jwks.json

# CORS — the public SPA origin (Vercel)
CORS_ALLOWED_ORIGINS=https://<app>.vercel.app

JAVA_TOOL_OPTIONS=-Xmx256m
